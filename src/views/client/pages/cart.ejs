<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Giỏ Hàng - Cơm Quê</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/comque-design.css">
</head>
<body>
    <%- include('../../partials/navbar') %>

    <div class="page-header">
        <h1>Giỏ Hàng</h1>
        <div class="breadcrumb">
            <a href="/">Cơm Quê</a>
            <span>›</span>
            <span>Giỏ Hàng</span>
        </div>
    </div>

    <div class="cart-page">
        <% if (cart && cart.length > 0) { %>
            <div class="cart-table-wrapper">
                <table class="cart-table">
                    <thead>
                        <tr>
                            <th>Thao tác</th>
                            <th>Hình ảnh</th>
                            <th>Sản phẩm</th>
                            <th>Số lượng</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% let total = 0; const price = pricing || {}; %>
                        <% cart.forEach(item => { %>
                            <% total += item.price * item.quantity; %>
                            <tr>
                                <td><a href="/cart/remove/<%= item.cart_item_id %>" class="btn-remove">✕</a></td>
                                <td><img src="/images/<%= item.image_url %>" alt="<%= item.dish_name %>" style="width:60px;height:60px;object-fit:cover;border-radius:8px"></td>
                                <td style="font-weight:600;color:#1a1a1a"><%= item.dish_name %> <% if(item.is_combo) { %><span style="font-size:.75rem;color:#E8192C;margin-left:6px;">COMBO</span><% } %></td>
                                <td>
                                    <div class="qty-control">
                                        <a href="/cart/decrease/<%= item.cart_item_id %>" class="qty-btn">−</a>
                                        <span><%= item.quantity %></span>
                                        <a href="/cart/increase/<%= item.cart_item_id %>" class="qty-btn">+</a>
                                    </div>
                                </td>
                                <td class="item-total"><%= (item.price * item.quantity).toLocaleString('vi-VN') %> ₫</td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <div class="cart-coupon-row">
                <div class="cart-checkout-note" style="color:#666;line-height:1.6;">
                    Mã giảm giá sẽ được nhập ở bước <strong>Xác nhận đặt hàng</strong>, sau khi hệ thống tính phí giao hàng theo địa chỉ.
                </div>
                <button class="btn-update" onclick="location.reload()">Cập nhật giỏ hàng</button>
            </div>

            <div class="cart-summary">
                <div class="summary-box">
                    <h3>Tổng Đơn Hàng</h3>
                    <div class="summary-row">
                        <span>Tạm tính:</span>
                        <span><%= Number(price.subtotal || total).toLocaleString('vi-VN') %> ₫</span>
                    </div>
                    <div class="summary-row">
                        <span>Phí giao hàng:</span>
                        <span>Tính theo khoảng cách ở checkout</span>
                    </div>
                    <div class="shipping-note">Phí giao hàng sẽ được tính ở bước checkout theo địa chỉ giao hàng.</div>
                    <div class="summary-row total">
                        <span>Tạm tính:</span>
                        <span class="total-price"><%= Number(price.total || total).toLocaleString('vi-VN') %> ₫</span>
                    </div>
                    <a href="/checkout" class="btn-checkout">Tiến hành thanh toán</a>
                    <a href="/thuc-don" class="btn-continue">← Tiếp tục mua sắm</a>
                </div>
            </div>
        <% } else { %>
            <div class="cart-empty">
                <div class="empty-icon">🛒</div>
                <h3>Giỏ hàng đang trống</h3>
                <p>Hãy thêm món ăn vào giỏ để đặt món nhé!</p>
                <a href="/thuc-don" class="btn-primary">Xem Thực Đơn</a>
            </div>
        <% } %>
    </div>

    <%- include('../../partials/footer') %>
</body>
</html>
