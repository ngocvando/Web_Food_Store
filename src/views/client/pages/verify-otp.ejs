<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xác Thực OTP - Cơm Quê</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/comque-design.css">
</head>
<body>
    <%- include('../../partials/navbar') %>
    <div class="auth-page">
        <div class="auth-container" style="max-width:460px">
            <div class="auth-header">
                <svg width="40" height="40" viewBox="0 0 26 26" fill="none" style="margin:0 auto 12px"><path d="M13 2C8 2 4 6 4 11c0 3.5 2 6.5 5 8v3h8v-3c3-1.5 5-4.5 5-8 0-5-4-9-9-9z" fill="#E8192C"/><rect x="9" y="22" width="8" height="2" rx="1" fill="#E8192C"/></svg>
                <h2>Nhập Mã OTP</h2>
                <p>Mã xác thực đã được gửi đến <strong><%= email %></strong>.</p>
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-error"><%= error %></div>
            <% } %>
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="alert alert-success"><%= success %></div>
            <% } %>

            <form action="/verify-otp" method="POST" class="auth-form" data-validate-form="verify-otp">
                <div class="form-group">
                    <label>Mã OTP 6 số</label>
                    <input type="text" name="otp" placeholder="Nhập mã OTP" required minlength="6" maxlength="6" inputmode="numeric" pattern="^[0-9]{6}$" data-otp="true" data-error="Mã OTP phải gồm đúng 6 chữ số.">
                    <small class="field-hint">Nếu không thấy email, hãy kiểm tra thư mục Spam/Quảng cáo.</small>
                </div>
                <button type="submit" class="btn-auth">Xác Nhận OTP</button>
            </form>
            <p class="auth-switch">Chưa nhận được mã? <a href="/forgot-password">Gửi lại OTP</a></p>
        </div>
    </div>
    <%- include('../../partials/footer') %>
</body>
</html>
