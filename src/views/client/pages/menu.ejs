<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thực Đơn - Cơm Quê</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/comque-design.css">
</head>
<body>
    <%- include('../../partials/navbar') %>

    <div class="page-header">
        <h1>Thực Đơn Đặc Sắc</h1>
        <div class="breadcrumb">
            <a href="/">Cơm Quê</a>
            <span>›</span>
            <span>Thực Đơn</span>
        </div>
    </div>

    <div class="menu-page-layout">
        <!-- Sidebar -->
        <aside class="menu-sidebar">
            <div class="sidebar-box">
                <h3>Tìm Kiếm</h3>
                <div class="sidebar-search">
                    <input type="text" id="searchInput" placeholder="Tìm món ăn..." oninput="filterDishes()">
                    <button>🔍</button>
                </div>
            </div>

            <div class="sidebar-box">
                <h3>Danh Mục</h3>
                <ul class="cat-list" id="catList">
                    <li class="active" onclick="filterByCategory('all', this)">🍽️ Tất cả món (<%= dishes.length %>)</li>
                    <% categories.forEach((cat, idx) => {
                        const icons = ['🍜','🍚','🥗','🍲','🧃','🍰','🥘','🍤'];
                        const icon = icons[idx % icons.length];
                    %>
                        <li onclick="filterByCategory('<%= cat.category_name %>', this)">
                            <%= icon %> <%= cat.category_name %>
                            <span class="cat-count"><%= cat.dish_count %></span>
                        </li>
                    <% }) %>
                </ul>
            </div>

            <div class="sidebar-box">
                <h3>Món Mới Nhất</h3>
                <% (latestDishes && latestDishes.length ? latestDishes : dishes.slice(0,5)).slice(0,5).forEach(d => { %>
                    <div class="latest-item">
                        <img src="/images/<%= d.image_url %>" alt="<%= d.dish_name %>" onerror="this.src='/images/default-food.png'">
                        <div>
                            <div class="li-name"><%= d.dish_name %></div>
                            <div class="li-price"><%= Number(d.price).toLocaleString('vi-VN') %> ₫</div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </aside>

        <!-- Content -->
        <div class="menu-content">
            <div class="cat-tabs" id="catTabs">
                <button class="cat-tab active" onclick="filterByCategory('all', null, this)">Tất cả</button>
                <% categories.forEach(cat => { %>
                    <button class="cat-tab" onclick="filterByCategory('<%= cat.category_name %>', null, this)">
                        <%= cat.category_name %>
                    </button>
                <% }) %>
            </div>

            <div class="menu-count" id="menuCount">Hiển thị <strong><%= dishes.length %></strong> món ăn</div>

            <div class="menu-grid" id="menuGrid">
                <% dishes.forEach(dish => { %>
                    <div class="food-card" data-category="<%= dish.category_name %>" data-name="<%= dish.dish_name.toLowerCase() %>">
                        <div class="food-img-wrap">
                            <a href="/mon-an/<%= dish.dish_id %>" class="food-image-link"><img src="/images/<%= dish.image_url %>" alt="<%= dish.dish_name %>" class="food-image" onerror="this.src='/images/default-food.png'"></a>
                            <span class="food-badge-cat"><%= dish.category_name %></span>
                        </div>
                        <div class="food-info">
                            <h3 class="food-name"><a href="/mon-an/<%= dish.dish_id %>"><%= dish.dish_name %></a></h3>
                            <p class="food-desc"><%= dish.description %></p>
                            <div class="food-footer">
                                <span class="food-price"><%= Number(dish.price).toLocaleString('vi-VN') %> ₫</span>
                                <button class="btn-add" onclick="addToCart(event, '<%= dish.dish_id %>', '<%= dish.dish_name %>', '<%= dish.price %>', '<%= dish.image_url %>')">🛒 Thêm vào giỏ</button>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <% if (combos && combos.length > 0) { %>
            <div class="menu-count" style="margin-top:28px;"><strong>Combo ưu đãi</strong></div>
            <div class="menu-grid" id="comboGrid">
                <% combos.forEach(combo => { %>
                    <div class="food-card" data-category="Combo Tiết Kiệm" data-name="<%= combo.combo_name.toLowerCase() %>">
                        <div class="food-img-wrap">
                            <img src="/images/<%= combo.image_url || 'default-food.png' %>" alt="<%= combo.combo_name %>" class="food-image" onerror="this.src='/images/default-food.png'">
                            <span class="food-badge-cat">Combo</span>
                        </div>
                        <div class="food-info">
                            <h3 class="food-name"><%= combo.combo_name %></h3>
                            <p class="food-desc"><%= combo.description || combo.items_text || '' %></p>
                            <% if (combo.items_text) { %><p class="food-desc" style="font-size:.8rem;color:#666;">Gồm: <%= combo.items_text %></p><% } %>
                            <div class="food-footer">
                                <span class="food-price"><%= Number(combo.discount_price).toLocaleString('vi-VN') %> ₫</span>
                                <button class="btn-add" onclick="addComboToCart(event, '<%= combo.combo_id %>', '<%= combo.combo_name %>')">🎁 Thêm combo</button>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
            <% } %>

        </div>
    </div>

    <%- include('../../partials/footer') %>

    <script>
    let currentCat = 'all';

    // Nếu có query param ?cat=... thì tự động filter
    const urlParams = new URLSearchParams(window.location.search);
    const catParam = urlParams.get('cat');
    if (catParam) {
        currentCat = catParam;
        document.querySelectorAll('#catList li').forEach(li => {
            li.classList.remove('active');
            if (li.textContent.trim().includes(catParam)) li.classList.add('active');
        });
        document.querySelectorAll('.cat-tab').forEach(btn => {
            btn.classList.remove('active');
            if (btn.textContent.trim() === catParam) btn.classList.add('active');
        });
        filterDishes();
    }

    function filterByCategory(cat, sidebarEl, tabEl) {
        currentCat = cat;
        document.querySelectorAll('#catList li').forEach(li => li.classList.remove('active'));
        if (sidebarEl) sidebarEl.classList.add('active');
        document.querySelectorAll('.cat-tab').forEach(btn => btn.classList.remove('active'));
        if (tabEl) tabEl.classList.add('active');
        filterDishes();
    }

    function filterDishes() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        const cards = document.querySelectorAll('#menuGrid .food-card');
        let count = 0;
        cards.forEach(card => {
            const matchCat = currentCat === 'all' || card.dataset.category === currentCat;
            const matchQ = !q || card.dataset.name.includes(q);
            const show = matchCat && matchQ;
            card.style.display = show ? '' : 'none';
            if (show) count++;
        });
        document.getElementById('menuCount').innerHTML = `Hiển thị <strong>${count}</strong> món ăn`;
    }
    </script>
<script src="/js/cart.js"></script>
</body>
</html>
