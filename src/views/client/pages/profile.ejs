<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hồ sơ cá nhân - Cơm Quê</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/comque-design.css">
    <style>
        .profile-wrap{max-width:1100px;margin:34px auto 70px;padding:0 20px;display:grid;grid-template-columns:1fr 1fr;gap:24px}
        .profile-card{background:#fff;border-radius:18px;padding:26px;box-shadow:0 10px 30px rgba(0,0,0,.06);border:1px solid #eee}
        .profile-card h3{margin:0 0 16px;color:#222}
        .profile-form .form-group{margin-bottom:14px}
        .profile-form label{font-weight:700;display:block;margin-bottom:6px;color:#333}
        .profile-form input,.profile-form textarea{width:100%;padding:12px 14px;border:1.5px solid #e0e0e0;border-radius:10px;font-size:.95rem}
        .profile-form input[readonly]{background:#f7f7f7;color:#777}
        .profile-help{font-size:.84rem;color:#777;margin-top:6px;line-height:1.5}
        .profile-alert{padding:12px 14px;border-radius:10px;margin-bottom:14px;font-weight:600}
        .profile-alert.success{background:#eaf8ef;color:#168033}
        .profile-alert.error{background:#ffecec;color:#c0392b}
        .btn-profile{border:0;background:#E8192C;color:#fff;border-radius:10px;padding:12px 18px;font-weight:800;cursor:pointer}
        .btn-password{border:0;background:#222;color:#fff;border-radius:10px;padding:12px 18px;font-weight:800;cursor:pointer}
        @media(max-width:900px){.profile-wrap{grid-template-columns:1fr}}
    </style>
</head>
<body>
<%- include('../../partials/navbar') %>
<div class="page-header">
    <h1>👤 Hồ Sơ Cá Nhân</h1>
    <p>Quản lý thông tin tài khoản và đổi mật khẩu</p>
</div>

<div class="profile-wrap">
    <div class="profile-card">
        <h3>Thông tin tài khoản</h3>
        <% if(success) { %><div class="profile-alert success">✅ Cập nhật hồ sơ thành công.</div><% } %>
        <% if(error) { %><div class="profile-alert error">❌ <%= error %></div><% } %>
        <form action="/profile" method="POST" class="profile-form">
            <div class="form-group">
                <label>Tên đăng nhập</label>
                <input type="text" value="<%= profileUser.username || '' %>" readonly>
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" value="<%= profileUser.email || '' %>" readonly>
                <p class="profile-help">Email dùng cho đăng nhập và OTP quên mật khẩu nên không chỉnh sửa tại đây.</p>
            </div>
            <div class="form-group">
                <label>Họ tên</label>
                <input type="text" name="full_name" value="<%= profileUser.full_name || '' %>" required data-fullname="true">
            </div>
            <div class="form-group">
                <label>Số điện thoại</label>
                <input type="tel" name="phone" value="<%= profileUser.phone || '' %>" maxlength="10" pattern="^(03|05|07|08|09)[0-9]{8}$" required data-phone="true">
                <p class="profile-help">Số điện thoại Việt Nam gồm đúng 10 số, bắt đầu bằng 03, 05, 07, 08 hoặc 09.</p>
            </div>
            <div class="form-group">
                <label>Địa chỉ mặc định</label>
                <textarea name="address" rows="4" required placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành phố"><%= profileUser.address || '' %></textarea>
            </div>
            <button class="btn-profile" type="submit">💾 Lưu hồ sơ</button>
        </form>
    </div>

    <div class="profile-card">
        <h3>Đổi mật khẩu</h3>
        <% if(passwordSuccess) { %><div class="profile-alert success">✅ Đổi mật khẩu thành công.</div><% } %>
        <% if(passwordError) { %><div class="profile-alert error">❌ <%= passwordError %></div><% } %>
        <form action="/profile/change-password" method="POST" class="profile-form">
            <div class="form-group">
                <label>Mật khẩu hiện tại</label>
                <input type="password" name="current_password" required autocomplete="current-password">
            </div>
            <div class="form-group">
                <label>Mật khẩu mới</label>
                <input type="password" name="new_password" required minlength="8" maxlength="60" autocomplete="new-password">
                <p class="profile-help">Mật khẩu mới phải có ít nhất 8 ký tự.</p>
            </div>
            <div class="form-group">
                <label>Nhập lại mật khẩu mới</label>
                <input type="password" name="confirm_password" required minlength="8" maxlength="60" autocomplete="new-password">
            </div>
            <button class="btn-password" type="submit">🔐 Đổi mật khẩu</button>
        </form>
    </div>
</div>

<%- include('../../partials/footer') %>
<script src="/js/input-logic.js"></script>
</body>
</html>
