<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đặt Hàng - Cơm Quê</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/comque-design.css">
</head>
<body>
    <%- include('../../partials/navbar') %>
    <div class="page-header">
        <h1>📦 Xác Nhận Đặt Hàng</h1>
        <p>Kiểm tra đơn hàng và nhập địa chỉ giao hàng</p>
    </div>

    <div class="checkout-page">
        <!-- Cột trái: Form -->
        <div class="checkout-left">
            <form action="/checkout" method="POST" id="checkoutForm">
                <input type="hidden" name="coupon_code" value="<%= pricing && pricing.couponCode ? pricing.couponCode : '' %>">
                <input type="hidden" name="delivery_lat" id="deliveryLat" value="<%= old.delivery_lat || '' %>">
                <input type="hidden" name="delivery_lng" id="deliveryLng" value="<%= old.delivery_lng || '' %>">
                <input type="hidden" name="distance_km" id="distanceKm" value="<%= pricing && pricing.distanceKm ? pricing.distanceKm : (old.distance_km || '') %>">
                <input type="hidden" name="address_signature" id="addressSignature" value="<%= old.address_signature || '' %>">
                <!-- Thông tin giao hàng -->
                <div class="admin-card delivery-card" style="margin-bottom:20px;">
                    <div class="delivery-card-head">
                        <div>
                            <h3>📍 Địa Chỉ Giao Hàng</h3>
                            <p>Nhập đủ thông tin để shipper giao đúng nơi. Địa chỉ mới sẽ được lưu cho lần sau.</p>
                        </div>
                        <span class="delivery-badge"><%= hasSavedAddress ? 'Đã có địa chỉ lưu' : 'Cần nhập địa chỉ' %></span>
                    </div>

                    <% if (hasSavedAddress) { %>
                        <div class="checkout-alert success">
                            Đã tự động điền địa chỉ đã lưu. Bạn có thể chỉnh sửa trước khi đặt hàng.
                        </div>
                    <% } else { %>
                        <div class="checkout-alert warning">
                            Tài khoản chưa có địa chỉ. Vui lòng nhập đầy đủ địa chỉ giao hàng, hệ thống sẽ lưu lại cho lần sau.
                        </div>
                    <% } %>
                    <% if (error) { %>
                        <div class="checkout-alert danger"><%= error %></div>
                    <% } %>
                    <% if (!settings || !settings.google_maps_api_key) { %>
                        <div class="checkout-alert warning">
                            Google Maps API chưa được cấu hình nên hệ thống chưa thể gợi ý địa chỉ tự động. Admin cần cấu hình API key và bật Maps JavaScript API, Places API, Geocoding API.
                        </div>
                    <% } %>

                    <div class="delivery-form-grid">
                        <div class="form-group">
                            <label>Họ tên người nhận <span class="required">*</span></label>
                            <input type="text" name="receiver_name" value="<%= old.receiver_name || userInfo.full_name || '' %>" required placeholder="Tên người nhận" maxlength="80" data-fullname="true" data-trim="true" data-error="Họ tên chỉ gồm chữ cái, khoảng trắng và không chứa số/ký tự đặc biệt.">
                        </div>
                        <div class="form-group">
                            <label>Số điện thoại <span class="required">*</span></label>
                            <input type="tel" name="phone" value="<%= old.phone || userInfo.phone || '' %>" placeholder="0912345678" required pattern="^(03|05|07|08|09)[0-9]{8}$" minlength="10" maxlength="10" inputmode="numeric" data-phone="true" data-error="Số điện thoại phải đúng 10 số và bắt đầu bằng 03, 05, 07, 08 hoặc 09.">
                        </div>
                        <div class="form-group full">
                            <label>Địa chỉ giao hàng <span class="required">*</span></label>
                            <input id="googleAddressSearch" class="address-input" type="text" name="address_detail" value="<%= old.address_detail || savedAddress.address_detail || '' %>" placeholder="Nhập địa chỉ để Google Maps gợi ý, ví dụ: Số 4 Hàng Chiếu" autocomplete="off" required>
                        </div>
                        <div class="form-group">
                            <label>Phường/Xã <span class="required">*</span></label>
                            <input class="address-input" type="text" name="ward" value="<%= old.ward || savedAddress.ward || '' %>" placeholder="VD: Phường Thanh Xuân Trung" required>
                        </div>
                        <div class="form-group">
                            <label>Quận/Huyện <span class="required">*</span></label>
                            <input class="address-input" type="text" name="district" value="<%= old.district || savedAddress.district || '' %>" placeholder="VD: Quận Thanh Xuân" required>
                        </div>
                        <div class="form-group full">
                            <label>Tỉnh/Thành phố <span class="required">*</span></label>
                            <input class="address-input" type="text" name="province" value="<%= old.province || savedAddress.province || '' %>" placeholder="VD: Hà Nội" required>
                        </div>
                    </div>

                    <div class="map-preview-card">
                        <div class="map-preview-head">
                            <div>
                                <strong>🗺️ Bản đồ địa chỉ giao hàng</strong>
                                <p id="map-address-text">Nhập địa chỉ để xem vị trí gần đúng trên bản đồ.</p>
                            </div>
                            <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;">
                                <button type="button" class="btn-map-refresh" onclick="useCurrentLocation()">📍 Dùng vị trí hiện tại</button>
                                <button type="button" class="btn-map-refresh" onclick="calculateShippingByAddress()">Tính phí ship</button>
                            </div>
                        </div>
                        <iframe id="deliveryMap" title="Bản đồ địa chỉ giao hàng" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="https://maps.google.com/maps?q=Vi%E1%BB%87t%20Nam&output=embed"></iframe>
                        <small class="map-note">Bản đồ dùng Google Maps để xem vị trí tương đối. Vui lòng kiểm tra lại số nhà, đường, phường/xã trước khi đặt hàng.</small>
                        <div id="shippingCalcBox" class="shipping-calc-box" style="margin-top:12px;padding:12px 14px;border-radius:12px;background:#f8f8ff;border:1px solid #e6e0f5;color:#37352f;line-height:1.6;">
                            🚚 <strong>Phí ship kiểu GrabFood:</strong> <span id="shippingCalcText"><%= pricing && pricing.shippingMessage ? pricing.shippingMessage : 'Bấm “Tính phí ship” sau khi nhập địa chỉ.' %></span>
                        </div>
                    </div>
                </div>

                <!-- Ghi chú -->
                <div class="admin-card" style="margin-bottom:20px;">
                    <h3 style="margin-bottom:12px;">📝 Ghi Chú</h3>
                    <textarea name="note" rows="2" placeholder="VD: Ít cay, giao trước 12h..." style="width:100%;padding:10px;border:1.5px solid #e0e0e0;border-radius:8px;resize:none;font-size:0.9rem;"></textarea>
                </div>

                <!-- Phương thức thanh toán -->
                <div class="admin-card" style="margin-bottom:20px;">
                    <h3 style="margin-bottom:16px;">💳 Phương Thức Thanh Toán</h3>
                    <div class="payment-options">
                        <label class="payment-option" id="opt-cod">
                            <input type="radio" name="payment_method" value="COD" checked onchange="togglePayment('COD')">
                            <div class="payment-option-inner">
                                <span class="payment-icon">💵</span>
                                <div>
                                    <strong>Tiền mặt khi nhận (COD)</strong>
                                    <small>Thanh toán khi nhận hàng</small>
                                </div>
                            </div>
                        </label>
                        <label class="payment-option" id="opt-banking">
                            <input type="radio" name="payment_method" value="Banking" onchange="togglePayment('Banking')">
                            <div class="payment-option-inner">
                                <span class="payment-icon">🏦</span>
                                <div>
                                    <strong>Chuyển khoản ngân hàng</strong>
                                    <small>QR sẽ được tạo sau khi đặt hàng</small>
                                </div>
                            </div>
                        </label>
                    </div>

                    <!-- VietQR Banking Note -->
                    <div id="qr-panel" class="vietqr-checkout-note" style="display:none; margin-top:18px;">
                        <div style="background:#fff8e8;border:1px solid #ffe0a3;border-radius:14px;padding:16px 18px;color:#8a5a00;line-height:1.65;">
                            <strong>ℹ️ Thanh toán VietQR</strong><br>
                            Mã QR chính thức sẽ được tạo sau khi đơn hàng được tạo thành công.
                            Vui lòng quét QR ở trang thanh toán của đơn hàng và nhập đúng nội dung chuyển khoản theo mã đơn.
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-checkout" style="width:100%;padding:16px;font-size:1.05rem;">
                    🛍️ Đặt Hàng Ngay
                </button>
            </form>
        </div>

        <!-- Cột phải: Tóm tắt -->
        <div class="checkout-right">
            <div class="admin-card">
                <h3 style="margin-bottom:16px;">🧾 Đơn Hàng Của Bạn</h3>
                <div class="order-items-list">
                <% let displayTotal = 0; const price = pricing || {}; cart.forEach(item => { displayTotal += item.price * item.quantity; %>
                    <div class="order-item-row">
                        <img src="/images/<%= item.image_url %>" onerror="this.src='/images/default-food.png'" style="width:42px;height:42px;border-radius:8px;object-fit:cover;">
                        <div class="order-item-info">
                            <strong><%= item.dish_name %></strong>
                            <small>x<%= item.quantity %></small>
                        </div>
                        <span class="order-item-price"><%= (item.price * item.quantity).toLocaleString('vi-VN') %> ₫</span>
                    </div>
                <% }) %>
                </div>
                <div class="summary-row" style="margin-top:16px;padding-top:14px;border-top:2px solid #f0f0f0;">
                    <span>Tạm tính:</span><span><%= Number(price.subtotal || displayTotal).toLocaleString('vi-VN') %> ₫</span>
                </div>
                <div class="summary-row"><span>Khoảng cách:</span><span id="summaryDistance"><%= price.distanceKm ? Number(price.distanceKm).toFixed(1) + ' km' : 'Chưa tính' %></span></div>
                <div class="summary-row"><span>Phí giao hàng:</span><span id="summaryShipping"><%= Number(price.shippingAmount || 0).toLocaleString('vi-VN') %> ₫</span></div>
                <div class="checkout-coupon-box" style="margin:14px 0;padding:14px;border:1px solid #eee;border-radius:12px;background:#fafafa;">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:10px;">
                        <strong>🎟️ Voucher đang có</strong>
                        <small style="color:#777;">Chọn mã phù hợp rồi áp dụng</small>
                    </div>

                    <% if (activeVouchers && activeVouchers.length) { %>
                        <div class="voucher-public-list">
                            <% activeVouchers.forEach(v => {
                                const type = (v.discount_type || '').toLowerCase();
                                const label = type === 'percent' ? ('Giảm ' + Number(v.discount_value || 0).toLocaleString('vi-VN') + '%')
                                    : (type === 'freeship' ? (Number(v.discount_value || 0) > 0 ? 'Giảm ship tối đa ' + Number(v.discount_value || 0).toLocaleString('vi-VN') + 'đ' : 'Miễn phí ship')
                                    : ('Giảm ' + Number(v.discount_value || 0).toLocaleString('vi-VN') + 'đ'));
                                const endText = v.end_date ? new Date(v.end_date).toLocaleDateString('vi-VN') : 'Không giới hạn';
                            %>
                                <button type="button" class="voucher-chip" data-code="<%= v.code %>" onclick="selectVoucher('<%= v.code %>')">
                                    <span class="voucher-chip-code"><%= v.code %></span>
                                    <span class="voucher-chip-desc"><%= label %></span>
                                    <span class="voucher-chip-date">HSD: <%= endText %></span>
                                </button>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div style="color:#777;font-size:.9rem;margin-bottom:10px;">Hiện chưa có voucher đang hoạt động.</div>
                    <% } %>

                    <form id="couponForm" class="coupon-group" action="/checkout/apply-coupon" method="POST" style="display:flex;gap:8px;margin-top:12px;">
                        <input id="couponInput" type="text" name="coupon_code" value="<%= price.couponCode || '' %>" placeholder="Nhập mã voucher..." autocomplete="off" maxlength="50" data-uppercase="true" data-voucher="true" data-nospace="true" style="flex:1;">
                        <button type="submit">Áp dụng</button>
                    </form>
                    <div id="couponSuccess" class="coupon-message success" style="margin-top:8px;<%= couponMessage ? '':'display:none;' %>"><%= couponMessage || '' %></div>
                    <div id="couponError" class="coupon-message error" style="margin-top:8px;<%= (couponError || price.couponError) ? '':'display:none;' %>"><%= couponError || price.couponError || '' %></div>
                    <button id="removeCouponBtn" type="button" class="btn-remove-coupon" style="margin-top:8px;<%= price.couponCode ? '' : 'display:none;' %>">Bỏ voucher</button>
                </div>
                <div id="summaryDiscountRow" class="summary-row discount-row" style="<%= Number(price.discountAmount || 0) > 0 ? '' : 'display:none;' %>">
                    <span id="summaryDiscountLabel">Giảm giá món (<%= price.couponCode || '' %>):</span>
                    <span id="summaryDiscountAmount">-<%= Number(price.discountAmount || 0).toLocaleString('vi-VN') %> ₫</span>
                </div>
                <div id="summaryShippingDiscountRow" class="summary-row discount-row" style="<%= Number(price.shippingDiscountAmount || 0) > 0 ? '' : 'display:none;' %>">
                    <span id="summaryShippingDiscountLabel">Giảm phí ship (<%= price.couponCode || '' %>):</span>
                    <span id="summaryShippingDiscount">-<%= Number(price.shippingDiscountAmount || 0).toLocaleString('vi-VN') %> ₫</span>
                </div>
                <div class="shipping-note" id="shippingNote"><%= price.shippingMessage || 'Phí ship được tính theo khoảng cách từ cửa hàng đến địa chỉ giao hàng.' %></div>
                <div class="summary-row" style="margin-top:10px;padding-top:12px;border-top:2px solid #f0f0f0;font-weight:800;font-size:1.05rem;">
                    <span>Tổng cộng:</span>
                    <span id="summaryTotal" style="color:#E8192C;"><%= Number(price.total || displayTotal).toLocaleString('vi-VN') %> ₫</span>
                </div>
            </div>
        </div>
    </div>

    <script>
    function selectVoucher(code) {
        const input = document.getElementById('couponInput');
        const voucherCode = (code || '').toUpperCase();
        if (input) {
            input.value = voucherCode;
            input.focus();
        }

        document.querySelectorAll('.voucher-chip').forEach(btn => {
            btn.classList.toggle('selected', btn.dataset.code === voucherCode);
        });

        showMessage('couponSuccess', 'Đã chọn voucher ' + voucherCode + '. Bấm Áp dụng để sử dụng.');
        showMessage('couponError', '');
    }
    function togglePayment(method) {
        const qrPanel = document.getElementById('qr-panel');
        qrPanel.style.display = method === 'Banking' ? 'block' : 'none';
        document.getElementById('opt-cod').classList.toggle('selected', method === 'COD');
        document.getElementById('opt-banking').classList.toggle('selected', method === 'Banking');
    }
    function getDeliveryAddress() {
        const fields = ['address_detail', 'ward', 'district', 'province'];
        return fields.map(name => {
            const el = document.querySelector(`[name="${name}"]`);
            return el ? el.value.trim() : '';
        }).filter(Boolean).join(', ');
    }
    function makeAddressSignature() {
        return getDeliveryAddress().toLowerCase().replace(/\s+/g, ' ').trim();
    }
    function resetShippingResult() {
        document.getElementById('deliveryLat').value = '';
        document.getElementById('deliveryLng').value = '';
        document.getElementById('distanceKm').value = '';
        document.getElementById('addressSignature').value = '';
        document.getElementById('summaryDistance').textContent = 'Chưa tính';
        document.getElementById('summaryShipping').textContent = 'Chưa tính';
        setRowVisible('summaryShippingDiscountRow', false);
        document.getElementById('summaryShippingDiscount').textContent = '-0 ₫';
        document.getElementById('shippingNote').textContent = 'Vui lòng bấm “Tính phí ship” hoặc “Dùng vị trí hiện tại” sau khi nhập địa chỉ.';
        document.getElementById('shippingCalcText').textContent = 'Địa chỉ đã thay đổi, vui lòng tính lại phí ship.';
        document.getElementById('summaryTotal').textContent = money(subtotalAmount - discountAmount);
    }

    function updateDeliveryMap() {
        const address = getDeliveryAddress();
        const text = document.getElementById('map-address-text');
        const iframe = document.getElementById('deliveryMap');
        if (!iframe) return;
        const query = address || 'Việt Nam';
        iframe.src = `https://maps.google.com/maps?q=${encodeURIComponent(query)}&output=embed`;
        if (text) {
            text.textContent = address || 'Nhập địa chỉ để xem vị trí gần đúng trên bản đồ.';
        }
    }


    const shopLat = Number('<%= pricing && pricing.shopLat ? pricing.shopLat : 20.64637 %>');
    const shopLng = Number('<%= pricing && pricing.shopLng ? pricing.shopLng : 106.05112 %>');
    const shopAddress = '<%- (pricing && pricing.shopAddress ? pricing.shopAddress : "Cơm Quê, Hưng Yên").replace(/'/g, "\\'") %>';
    const shippingBaseFee = Number('<%= pricing && pricing.shippingBaseFee ? pricing.shippingBaseFee : 15000 %>');
    const shippingBaseKm = Number('<%= pricing && pricing.shippingBaseKm ? pricing.shippingBaseKm : 3 %>');
    const shippingPerKm = Number('<%= pricing && pricing.shippingPerKm ? pricing.shippingPerKm : 3000 %>');
    const shippingMaxKm = Number('<%= pricing && pricing.shippingMaxKm ? pricing.shippingMaxKm : 20 %>');
    const subtotalAmount = Number('<%= pricing && pricing.subtotal ? pricing.subtotal : 0 %>');
    let discountAmount = Number('<%= pricing && pricing.discountAmount ? pricing.discountAmount : 0 %>');
    let couponType = '<%= pricing && pricing.coupon && pricing.coupon.discount_type ? pricing.coupon.discount_type : '' %>';
    let couponValue = Number('<%= pricing && pricing.coupon && pricing.coupon.discount_value ? pricing.coupon.discount_value : 0 %>');
    let selectedGooglePlace = null;

    function money(v) { return Math.max(0, Math.round(Number(v || 0))).toLocaleString('vi-VN') + ' ₫'; }

    function showMessage(id, text) {
        const el = document.getElementById(id);
        if (!el) return;
        el.textContent = text || '';
        el.style.display = text ? 'block' : 'none';
    }
    function setRowVisible(id, visible) {
        const el = document.getElementById(id);
        if (el) el.style.display = visible ? '' : 'none';
    }
    function getCurrentDeliveryPayload() {
        return {
            distance_km: document.getElementById('distanceKm')?.value || '',
            delivery_lat: document.getElementById('deliveryLat')?.value || '',
            delivery_lng: document.getElementById('deliveryLng')?.value || ''
        };
    }
    function updateSummaryFromPricing(data) {
        if (!data) return;
        couponType = (data.couponType || '').toLowerCase();
        couponValue = Number(data.couponValue || 0);
        discountAmount = Number(data.discountAmount || 0);

        const hiddenCoupon = document.querySelector('input[name="coupon_code"][type="hidden"]');
        if (hiddenCoupon) hiddenCoupon.value = data.couponCode || '';

        const couponInput = document.getElementById('couponInput');
        if (couponInput && data.couponCode) couponInput.value = data.couponCode;

        if (Number(data.distanceKm || 0) > 0) {
            document.getElementById('distanceKm').value = Number(data.distanceKm).toFixed(2);
            document.getElementById('summaryDistance').textContent = Number(data.distanceKm).toFixed(1) + ' km';
        }

        document.getElementById('summaryShipping').textContent = money(data.shippingAmount || 0);

        setRowVisible('summaryDiscountRow', Number(data.discountAmount || 0) > 0);
        document.getElementById('summaryDiscountLabel').textContent = `Giảm giá món (${data.couponCode || ''}):`;
        document.getElementById('summaryDiscountAmount').textContent = '-' + money(data.discountAmount || 0);

        setRowVisible('summaryShippingDiscountRow', Number(data.shippingDiscountAmount || 0) > 0);
        document.getElementById('summaryShippingDiscountLabel').textContent = `Giảm phí ship (${data.couponCode || ''}):`;
        document.getElementById('summaryShippingDiscount').textContent = '-' + money(data.shippingDiscountAmount || 0);

        document.getElementById('summaryTotal').textContent = money(data.total || 0);
        document.getElementById('shippingCalcText').textContent = data.shippingMessage || 'Bấm “Tính phí ship” sau khi nhập địa chỉ.';
        document.getElementById('shippingNote').textContent = data.shippingMessage || 'Phí ship được tính theo khoảng cách từ cửa hàng đến địa chỉ giao hàng.';

        const removeBtn = document.getElementById('removeCouponBtn');
        if (removeBtn) removeBtn.style.display = data.couponCode ? '' : 'none';
    }
    async function postVoucher(url, code) {
        const body = new URLSearchParams();
        body.set('ajax', '1');
        if (code) body.set('coupon_code', (code || '').toUpperCase());
        const delivery = getCurrentDeliveryPayload();
        Object.keys(delivery).forEach(key => body.set(key, delivery[key] || ''));

        const res = await fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
                'Accept': 'application/json'
            },
            body
        });
        return await res.json();
    }
    async function applyVoucherAjax(code) {
        const input = document.getElementById('couponInput');
        const voucherCode = (code || input?.value || '').trim().toUpperCase();
        if (input) input.value = voucherCode;

        showMessage('couponSuccess', '');
        showMessage('couponError', '');

        try {
            const data = await postVoucher('/checkout/apply-coupon', voucherCode);
            updateSummaryFromPricing(data);
            if (data.success) showMessage('couponSuccess', data.message || 'Đã áp dụng voucher.');
            else showMessage('couponError', data.message || data.couponError || 'Không thể áp dụng voucher.');
        } catch (error) {
            showMessage('couponError', 'Không thể áp dụng voucher. Vui lòng thử lại.');
        }
    }
    async function removeVoucherAjax() {
        showMessage('couponSuccess', '');
        showMessage('couponError', '');

        try {
            const data = await postVoucher('/checkout/remove-coupon', '');
            updateSummaryFromPricing(data);
            const input = document.getElementById('couponInput');
            if (input) input.value = '';
            showMessage('couponSuccess', data.message || 'Đã bỏ voucher.');
        } catch (error) {
            showMessage('couponError', 'Không thể bỏ voucher. Vui lòng thử lại.');
        }
    }
    function haversineKm(lat1, lon1, lat2, lon2) {
        const R = 6371;
        const toRad = deg => deg * Math.PI / 180;
        const dLat = toRad(lat2 - lat1);
        const dLon = toRad(lon2 - lon1);
        const a = Math.sin(dLat/2) ** 2 + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon/2) ** 2;
        return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    }
    function calcGrabShipping(distanceKm) {
        if (distanceKm > shippingMaxKm) return { blocked: true, fee: 0 };
        const extraKm = Math.max(0, Math.ceil(distanceKm - shippingBaseKm));
        return { blocked: false, fee: shippingBaseFee + extraKm * shippingPerKm };
    }
    function applyShippingResult(distance, lat, lng, messagePrefix) {
        const ship = calcGrabShipping(distance);
        document.getElementById('deliveryLat').value = Number(lat).toFixed(7);
        document.getElementById('deliveryLng').value = Number(lng).toFixed(7);
        document.getElementById('distanceKm').value = distance.toFixed(2);
        document.getElementById('addressSignature').value = makeAddressSignature();
        document.getElementById('summaryDistance').textContent = distance.toFixed(1) + ' km';
        if (ship.blocked) {
            const msg = `Địa chỉ cách cửa hàng ${distance.toFixed(1)} km, vượt phạm vi giao hàng ${shippingMaxKm} km.`;
            document.getElementById('shippingCalcText').textContent = msg;
            document.getElementById('summaryShipping').textContent = 'Không hỗ trợ';
            document.getElementById('shippingNote').textContent = msg;
            setRowVisible('summaryShippingDiscountRow', false);
            document.getElementById('summaryShippingDiscount').textContent = '-0 ₫';
            document.getElementById('summaryTotal').textContent = money(subtotalAmount - discountAmount);
            return;
        }
        const shippingDiscount = couponType === 'freeship'
            ? Math.min(ship.fee, couponValue > 0 ? couponValue : ship.fee)
            : 0;
        const msg = `Khoảng cách ${distance.toFixed(1)} km - Phí giao hàng ${money(ship.fee)}${shippingDiscount > 0 ? ' - Giảm phí ship ' + money(shippingDiscount) : ''}`;
        document.getElementById('shippingCalcText').textContent = msg;
        document.getElementById('summaryShipping').textContent = money(ship.fee);
        setRowVisible('summaryShippingDiscountRow', shippingDiscount > 0);
        document.getElementById('summaryShippingDiscount').textContent = '-' + money(shippingDiscount);
        document.getElementById('shippingNote').textContent = msg;
        document.getElementById('summaryTotal').textContent = money(subtotalAmount - discountAmount + ship.fee - shippingDiscount);
    }
    async function geocodeAddress(address) {
        const url = 'https://nominatim.openstreetmap.org/search?format=json&limit=1&countrycodes=vn&q=' + encodeURIComponent(address);
        const res = await fetch(url, { headers: { 'Accept': 'application/json' }});
        const data = await res.json();
        if (!data || !data.length) return null;
        return { lat: Number(data[0].lat), lng: Number(data[0].lon) };
    }
    function fillAddressFromGooglePlace(place) {
        if (!place || !place.address_components) return;
        const get = (...types) => {
            const comp = place.address_components.find(c => types.some(t => c.types.includes(t)));
            return comp ? comp.long_name : '';
        };
        const streetNo = get('street_number');
        const route = get('route');
        const sublocality = get('sublocality_level_1', 'sublocality', 'neighborhood');
        const ward = get('administrative_area_level_3', 'sublocality_level_1', 'ward') || sublocality;
        const district = get('administrative_area_level_2', 'locality');
        const province = get('administrative_area_level_1');
        const detail = [streetNo, route].filter(Boolean).join(' ') || (place.name || '');
        const setIf = (name, value) => {
            const el = document.querySelector(`[name="${name}"]`);
            if (el && value) el.value = value;
        };
        setIf('address_detail', detail || place.formatted_address);
        setIf('ward', ward);
        setIf('district', district);
        setIf('province', province);
    }

    function setAddressField(name, value) {
        const el = document.querySelector(`[name="${name}"]`);
        if (el && value) el.value = value;
    }
    function fillAddressFromNominatim(data) {
        if (!data) return;
        const address = data.address || {};
        const house = address.house_number || '';
        const road = address.road || address.pedestrian || address.footway || address.neighbourhood || '';
        const detail = [house, road].filter(Boolean).join(' ') || data.display_name || '';
        const ward = address.suburb || address.ward || address.quarter || address.neighbourhood || address.village || '';
        const district = address.city_district || address.county || address.town || address.city || '';
        const province = address.city || address.state || address.province || '';
        setAddressField('address_detail', detail);
        setAddressField('ward', ward);
        setAddressField('district', district);
        setAddressField('province', province);
    }
    async function reverseGeocode(lat, lng) {
        const url = `https://nominatim.openstreetmap.org/reverse?format=json&lat=${encodeURIComponent(lat)}&lon=${encodeURIComponent(lng)}&accept-language=vi`;
        const res = await fetch(url, { headers: { 'Accept': 'application/json' }});
        if (!res.ok) return null;
        return await res.json();
    }
    async function useCurrentLocation() {
        const box = document.getElementById('shippingCalcText');
        if (!navigator.geolocation) {
            alert('Trình duyệt không hỗ trợ lấy vị trí hiện tại.');
            return;
        }
        if (box) box.textContent = 'Đang lấy vị trí hiện tại...';
        navigator.geolocation.getCurrentPosition(async (position) => {
            try {
                const lat = position.coords.latitude;
                const lng = position.coords.longitude;
                document.getElementById('deliveryLat').value = Number(lat).toFixed(7);
                document.getElementById('deliveryLng').value = Number(lng).toFixed(7);
                const data = await reverseGeocode(lat, lng);
                fillAddressFromNominatim(data);
                selectedGooglePlace = null;
                updateDeliveryMap();
                const distance = haversineKm(shopLat, shopLng, lat, lng);
                applyShippingResult(distance, lat, lng, 'Khoảng cách ước tính');
            } catch (e) {
                if (box) box.textContent = 'Không thể tự động lấy địa chỉ từ vị trí hiện tại. Vui lòng nhập địa chỉ thủ công.';
            }
        }, () => {
            if (box) box.textContent = 'Không thể lấy vị trí hiện tại. Vui lòng cho phép quyền truy cập vị trí trên trình duyệt.';
            alert('Không thể lấy vị trí hiện tại. Vui lòng cho phép quyền truy cập vị trí.');
        }, {
            enableHighAccuracy: true,
            timeout: 10000,
            maximumAge: 60000
        });
    }
    function calculateDistanceByGoogle(destinationLat, destinationLng) {
        return new Promise((resolve) => {
            if (!window.google || !google.maps || !google.maps.DistanceMatrixService) return resolve(null);
            const service = new google.maps.DistanceMatrixService();
            service.getDistanceMatrix({
                origins: [{ lat: shopLat, lng: shopLng }],
                destinations: [{ lat: destinationLat, lng: destinationLng }],
                travelMode: google.maps.TravelMode.DRIVING,
                unitSystem: google.maps.UnitSystem.METRIC
            }, (response, status) => {
                if (status !== 'OK') return resolve(null);
                const element = response?.rows?.[0]?.elements?.[0];
                if (!element || element.status !== 'OK' || !element.distance) return resolve(null);
                resolve(element.distance.value / 1000);
            });
        });
    }
    async function calculateShippingByAddress() {
        updateDeliveryMap();
        const address = getDeliveryAddress();
        const box = document.getElementById('shippingCalcText');
        if (!address && !selectedGooglePlace) { box.textContent = 'Vui lòng nhập đầy đủ địa chỉ trước khi tính phí ship.'; return; }
        box.textContent = 'Đang định vị địa chỉ và tính phí ship...';
        try {
            let point = null;
            if (selectedGooglePlace && selectedGooglePlace.geometry && selectedGooglePlace.geometry.location) {
                point = {
                    lat: selectedGooglePlace.geometry.location.lat(),
                    lng: selectedGooglePlace.geometry.location.lng()
                };
            } else {
                point = await geocodeAddress(address);
            }
            if (!point) { box.textContent = 'Không định vị được địa chỉ. Vui lòng nhập rõ hơn số nhà, đường, phường/xã, quận/huyện, tỉnh/thành phố.'; return; }
            const roadDistance = await calculateDistanceByGoogle(point.lat, point.lng);
            const distance = roadDistance || haversineKm(shopLat, shopLng, point.lat, point.lng);
            applyShippingResult(distance, point.lat, point.lng, roadDistance ? 'Khoảng cách đường đi' : 'Khoảng cách ước tính');
        } catch (e) {
            box.textContent = 'Không thể tính phí ship tự động. Vui lòng kiểm tra kết nối mạng hoặc thử lại.';
        }
    }
    function initGoogleAddressAutocomplete() {
        const input = document.getElementById('googleAddressSearch');
        if (!input || !window.google || !google.maps || !google.maps.places) {
            const box = document.getElementById('shippingCalcText');
            if (box) box.textContent = 'Google Maps Autocomplete chưa sẵn sàng. Vui lòng kiểm tra API key hoặc bấm Tính phí ship để dùng định vị dự phòng.';
            return;
        }
        const autocomplete = new google.maps.places.Autocomplete(input, {
            componentRestrictions: { country: 'vn' },
            fields: ['address_components', 'formatted_address', 'geometry', 'name', 'place_id']
        });
        autocomplete.addListener('place_changed', async () => {
            selectedGooglePlace = autocomplete.getPlace();
            if (!selectedGooglePlace || !selectedGooglePlace.geometry) {
                document.getElementById('shippingCalcText').textContent = 'Không lấy được tọa độ từ địa chỉ đã chọn. Vui lòng chọn lại gợi ý khác.';
                return;
            }
            fillAddressFromGooglePlace(selectedGooglePlace);
            updateDeliveryMap();
            await calculateShippingByAddress();
        });
    }
    window.initGoogleAddressAutocomplete = initGoogleAddressAutocomplete;

    // Init
    document.getElementById('opt-cod').classList.add('selected');
    document.querySelectorAll('.payment-option input').forEach(r => {
        r.addEventListener('change', () => togglePayment(r.value));
    });

    const couponForm = document.getElementById('couponForm');
    if (couponForm) {
        couponForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            await applyVoucherAjax();
        });
    }
    const removeCouponBtn = document.getElementById('removeCouponBtn');
    if (removeCouponBtn) {
        removeCouponBtn.addEventListener('click', async () => {
            await removeVoucherAjax();
        });
    }
    document.querySelectorAll('.address-input').forEach(input => {
        input.addEventListener('input', () => {
            selectedGooglePlace = null;
            resetShippingResult();
            clearTimeout(window.__mapTimer);
            window.__mapTimer = setTimeout(updateDeliveryMap, 700);
        });
        input.addEventListener('blur', updateDeliveryMap);
    });
    const checkoutForm = document.getElementById('checkoutForm');
    if (checkoutForm) {
        checkoutForm.addEventListener('submit', (e) => {
            const distance = document.getElementById('distanceKm').value;
            const signature = document.getElementById('addressSignature').value;
            const currentSignature = makeAddressSignature();
            if (!distance || !signature || signature !== currentSignature) {
                e.preventDefault();
                alert('Vui lòng chọn địa chỉ hợp lệ từ Google Maps hoặc bấm “Tính phí ship” để tính lại phí giao hàng trước khi đặt hàng.');
                return false;
            }
        });
    }
    updateDeliveryMap();
    </script>
    <% if (settings && settings.google_maps_api_key) { %>
    <script async defer src="https://maps.googleapis.com/maps/api/js?key=<%= settings.google_maps_api_key %>&libraries=places&callback=initGoogleAddressAutocomplete"></script>
    <% } %>
    <%- include('../../partials/footer') %>
</body>
</html>
