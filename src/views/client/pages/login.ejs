<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Nhập - Cơm Quê</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/comque-design.css">
</head>
<body>
    <%- include('../../partials/navbar') %>
    <div class="auth-page">
        <div class="auth-container">
            <div class="auth-header">
                <svg width="40" height="40" viewBox="0 0 26 26" fill="none" style="margin:0 auto 12px"><path d="M13 2C8 2 4 6 4 11c0 3.5 2 6.5 5 8v3h8v-3c3-1.5 5-4.5 5-8 0-5-4-9-9-9z" fill="#E8192C"/><rect x="9" y="22" width="8" height="2" rx="1" fill="#E8192C"/></svg>
                <h2>Đăng Nhập</h2>
                <p>Chào mừng trở lại!</p>
            </div>
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-error"><%= error %></div>
            <% } %>
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="alert alert-success"><%= success %></div>
            <% } %>
            <form action="/login" method="POST" class="auth-form" data-validate-form="login">
                <div class="form-group">
                    <label>Tên đăng nhập</label>
                    <input type="text" name="username" placeholder="Nhập tên đăng nhập" value="<%= old && old.username ? old.username : '' %>" required autofocus maxlength="30" data-nospace="true" data-error="Vui lòng nhập tên đăng nhập.">
                </div>
                <div class="form-group">
                    <label>Mật khẩu</label>
                    <input type="password" name="password" placeholder="Nhập mật khẩu" required minlength="8" maxlength="60" autocomplete="current-password" data-error="Vui lòng nhập mật khẩu từ 8 ký tự.">
                </div>
                <button type="submit" class="btn-auth">Đăng Nhập</button>
            </form>
            <p class="auth-switch"><a href="/forgot-password">Quên mật khẩu?</a></p>
            <p class="auth-switch">Chưa có tài khoản? <a href="/register">Đăng ký ngay</a></p>
        </div>
    </div>
    <%- include('../../partials/footer') %>
</body>
</html>
