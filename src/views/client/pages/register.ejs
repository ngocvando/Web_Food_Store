<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Ký - Cơm Quê</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/comque-design.css">
</head>
<body>
    <%- include('../../partials/navbar') %>
    <div class="auth-page">
        <div class="auth-container" style="max-width:500px">
            <div class="auth-header">
                <svg width="40" height="40" viewBox="0 0 26 26" fill="none" style="margin:0 auto 12px"><path d="M13 2C8 2 4 6 4 11c0 3.5 2 6.5 5 8v3h8v-3c3-1.5 5-4.5 5-8 0-5-4-9-9-9z" fill="#E8192C"/><rect x="9" y="22" width="8" height="2" rx="1" fill="#E8192C"/></svg>
                <h2>Tạo Tài Khoản</h2>
                <p>Đăng ký để đặt món dễ dàng hơn!</p>
            </div>
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-error"><%= error %></div>
            <% } %>
            <form action="/register" method="POST" class="auth-form" data-validate-form="register">
                <div class="form-group"><label>Tên đăng nhập</label><input type="text" name="username" value="<%= old && old.username ? old.username : '' %>" placeholder="Tên đăng nhập" required minlength="4" maxlength="30" pattern="^[A-Za-z0-9_]{4,30}$" data-nospace="true" data-error="Tên đăng nhập 4-30 ký tự, chỉ gồm chữ, số và dấu _."><small class="field-hint">4-30 ký tự, không dấu cách.</small></div>
                <div class="form-group"><label>Mật khẩu</label><input type="password" name="password" placeholder="Mật khẩu" required minlength="8" maxlength="60" autocomplete="new-password" data-error="Mật khẩu phải có ít nhất 8 ký tự."></div>
                <div class="form-group"><label>Họ và tên</label><input type="text" name="full_name" value="<%= old && old.full_name ? old.full_name : '' %>" placeholder="Họ và tên đầy đủ" required maxlength="80" data-fullname="true" data-trim="true" data-error="Họ tên chỉ gồm chữ cái, khoảng trắng và không chứa số/ký tự đặc biệt."></div>
                <div class="form-group"><label>Email</label><input type="email" name="email" data-email="true" value="<%= old && old.email ? old.email : '' %>" placeholder="email@example.com" required maxlength="120" pattern="^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$" data-lowercase="true" data-error="Email không đúng định dạng."></div>
                <div class="form-group"><label>Số điện thoại</label><input type="tel" name="phone" value="<%= old && old.phone ? old.phone : '' %>" placeholder="0912345678" required pattern="^(03|05|07|08|09)[0-9]{8}$" minlength="10" maxlength="10" inputmode="numeric" data-phone="true" data-error="Số điện thoại phải đúng 10 số và bắt đầu bằng 03, 05, 07, 08 hoặc 09."></div>
                <button type="submit" class="btn-auth">Đăng Ký Ngay</button>
            </form>
            <p class="auth-switch">Đã có tài khoản? <a href="/login">Đăng nhập</a></p>
        </div>
    </div>
    <%- include('../../partials/footer') %>
</body>
</html>
