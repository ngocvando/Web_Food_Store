<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Hóa đơn #<%= order.order_id %> - Cơm Quê</title>
    <style>
        body{font-family:Arial,sans-serif;background:#f5f5f5;margin:0;color:#222}
        .invoice{max-width:820px;margin:30px auto;background:#fff;padding:34px;border-radius:16px;box-shadow:0 8px 30px rgba(0,0,0,.08)}
        .invoice-head{display:flex;justify-content:space-between;gap:20px;border-bottom:2px solid #eee;padding-bottom:18px;margin-bottom:22px}
        .brand h1{margin:0;color:#E8192C;font-size:30px}.brand p{margin:6px 0;color:#666}
        .meta{text-align:right}.meta h2{margin:0 0 8px}.meta p{margin:4px 0;color:#555}
        .info{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:22px}
        .box{background:#fafafa;border:1px solid #eee;border-radius:12px;padding:14px}
        .box h3{margin:0 0 8px;font-size:16px}.box p{margin:5px 0;color:#444}
        table{width:100%;border-collapse:collapse;margin-top:12px}
        th,td{padding:12px 8px;border-bottom:1px solid #eee;text-align:left}
        th{text-transform:uppercase;font-size:12px;color:#777}
        td.qty{text-align:center}.money{text-align:right}
        .totals{margin-left:auto;margin-top:18px;max-width:360px}
        .total-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px dashed #ddd}
        .grand{font-size:20px;font-weight:800;color:#E8192C;border-bottom:0}
        .actions{text-align:center;margin:20px auto}.actions button,.actions a{display:inline-block;border:0;background:#E8192C;color:#fff;padding:12px 18px;border-radius:10px;text-decoration:none;font-weight:800;cursor:pointer;margin:4px}
        .actions a{background:#222}
        @media print{body{background:#fff}.invoice{box-shadow:none;margin:0;max-width:none;border-radius:0}.actions{display:none}}
    </style>
</head>
<body>
<div class="invoice">
    <div class="invoice-head">
        <div class="brand">
            <h1>Cơm Quê</h1>
            <p><%= settings.shop_address || 'Cơm Quê' %></p>
            <p>Hóa đơn bán hàng</p>
        </div>
        <div class="meta">
            <h2>HÓA ĐƠN #<%= order.order_id %></h2>
            <p>Ngày đặt: <%= new Date(order.order_date).toLocaleString('vi-VN') %></p>
            <p>Trạng thái: <%= order.order_status %></p>
            <p>Thanh toán: <%= order.payment_method === 'Banking' ? 'VietQR' : 'COD' %></p>
        </div>
    </div>

    <div class="info">
        <div class="box">
            <h3>Khách hàng</h3>
            <p><strong><%= order.receiver_name || order.full_name || '' %></strong></p>
            <p>SĐT: <%= order.delivery_phone || '—' %></p>
            <p>Email: <%= order.email || '—' %></p>
        </div>
        <div class="box">
            <h3>Giao hàng</h3>
            <p><%= order.delivery_address || '—' %></p>
            <% if(order.distance_km) { %><p>Khoảng cách: <%= Number(order.distance_km).toFixed(1) %> km</p><% } %>
        </div>
    </div>

    <table>
        <thead>
            <tr><th>Món ăn</th><th class="qty">SL</th><th class="money">Đơn giá</th><th class="money">Thành tiền</th></tr>
        </thead>
        <tbody>
            <% items.forEach(item => { %>
                <tr>
                    <td><%= item.dish_name %></td>
                    <td class="qty"><%= item.quantity %></td>
                    <td class="money"><%= Number(item.price_at_time || 0).toLocaleString('vi-VN') %> ₫</td>
                    <td class="money"><%= (Number(item.price_at_time || 0) * Number(item.quantity || 0)).toLocaleString('vi-VN') %> ₫</td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <div class="totals">
        <div class="total-row"><span>Tạm tính</span><strong><%= Number(order.subtotal_amount || 0).toLocaleString('vi-VN') %> ₫</strong></div>
        <div class="total-row"><span>Phí giao hàng</span><strong><%= Number(order.shipping_fee || 0).toLocaleString('vi-VN') %> ₫</strong></div>
        <% if(Number(order.discount_amount || 0) > 0) { %>
            <div class="total-row"><span>Giảm giá món <%= order.discount_code ? '(' + order.discount_code + ')' : '' %></span><strong>-<%= Number(order.discount_amount || 0).toLocaleString('vi-VN') %> ₫</strong></div>
        <% } %>
        <% if(Number(order.shipping_discount_amount || 0) > 0) { %>
            <div class="total-row"><span>Giảm phí ship <%= order.discount_code ? '(' + order.discount_code + ')' : '' %></span><strong>-<%= Number(order.shipping_discount_amount || 0).toLocaleString('vi-VN') %> ₫</strong></div>
        <% } %>
        <div class="total-row grand"><span>Tổng cộng</span><strong><%= Number(order.total_amount || 0).toLocaleString('vi-VN') %> ₫</strong></div>
    </div>
</div>
<div class="actions">
    <button onclick="window.print()">🖨 In hóa đơn</button>
    <a href="/my-orders">← Quay lại đơn hàng</a>
</div>
</body>
</html>
