<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đánh Giá</title>
        <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/comque-design.css">
</head>
<body>
<div class="admin-layout">
    <%- include('../../partials/admin-sidebar', { page: 'reviews' }) %>
    <main class="admin-main">
        <div class="admin-topbar">
            <h2>⭐ Quản Lý Đánh Giá</h2>
            <span style="color:#888;font-size:0.9rem;">Tổng: <%= reviews.length %> đánh giá</span>
        </div>
        <div class="admin-card" style="margin:30px;">
            <% if(reviews.length === 0) { %>
                <p style="color:#aaa;text-align:center;padding:40px;">Chưa có đánh giá nào.</p>
            <% } else { %>
            <table class="admin-table">
                <thead><tr>
                    <th>Khách hàng</th><th>Sản phẩm</th><th>Đơn hàng</th><th>Đánh giá</th>
                    <th>Nhận xét</th><th>Ngày</th><th>Trạng thái</th><th>Thao tác</th>
                </tr></thead>
                <tbody>
                <% reviews.forEach(r => { %>
                <tr>
                    <td>
                        <strong><%= r.full_name %></strong>
                        <small style="display:block;color:#999;">@<%= r.username %></small>
                    </td>
                    <td><strong><%= r.item_name || "—" %></strong><small style="display:block;color:#999;"><%= r.item_type || "Món ăn" %></small></td>
                    <td>#<%= r.order_id || "—" %></td>
                    <td>
                        <div class="star-display">
                            <% for(let i=1;i<=5;i++) { %>
                                <span style="color:<%= i<=r.rating ? '#f39c12':'#ddd' %>">★</span>
                            <% } %>
                            <small>(<%= r.rating %>/5)</small>
                        </div>
                    </td>
                    <td style="max-width:250px;color:#555;font-size:0.9rem;">
                        <%= r.comment || '—' %>
                    </td>
                    <td style="color:#888;font-size:0.85rem;">
                        <%= new Date(r.created_at).toLocaleDateString('vi-VN') %>
                    </td>
                    <td><%= r.status || 'visible' %></td>
                    <td>
                        <form action="/admin/reviews/toggle/<%= r.review_id %>" method="POST" style="display:inline;">
                            <button type="submit" class="btn-action delete"><%= (r.status==='hidden'?'👁️ Hiện lại':'🙈 Ẩn') %></button>
                        </form>
                    </td>
                </tr>
                <% }) %>
                </tbody>
            </table>
            <% } %>
        </div>
    </main>
</div>
    </body>
</html>
