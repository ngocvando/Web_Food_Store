<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản Lý Món Ăn</title>
        <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/comque-design.css">
</head>
<body>
<div class="admin-layout">
    <%- include('../../partials/admin-sidebar', { page: 'dishes' }) %>
    <main class="admin-main">
        <div class="admin-topbar">
            <h2>🍽️ Quản Lý Món Ăn</h2>
            <a href="/admin/dishes/add" class="btn-admin-add">+ Thêm món mới</a>
        </div>
        <% if (typeof query !== 'undefined' && query.hidden) { %>
            <div class="alert alert-success" style="margin: 0 30px 16px;">
                Đã ẩn món ăn. Các combo có chứa món này cũng đã được tạm ngưng để tránh bán combo thiếu món.
            </div>
        <% } %>
        <div class="admin-card" style="margin:30px;">
            <div class="table-search">
                <input type="text" id="searchInput" placeholder="🔍 Tìm món ăn..." oninput="filterTable()">
            </div>
            <table class="admin-table" id="dishTable">
                <thead><tr>
                    <th>Hình ảnh</th><th>Tên món</th><th>Danh mục</th>
                    <th>Giá</th><th>Trạng thái</th><th>Thao tác</th>
                </tr></thead>
                <tbody>
                <% dishes.forEach(dish => { %>
                <tr>
                    <td><img src="/images/<%= dish.image_url %>" class="dish-thumb" onerror="this.src='/images/default-food.png'"></td>
                    <td class="dish-name-cell">
                        <strong><%= dish.dish_name %></strong>
                        <small><%= dish.description ? dish.description.substring(0,50)+'...' : '' %></small>
                    </td>
                    <td><span class="food-category"><%= dish.category_name %></span></td>
                    <td class="price-cell"><%= Number(dish.price).toLocaleString('vi-VN') %> ₫</td>
                    <td>
                        <% if(dish.is_available){ %>
                            <span class="status-badge status-completed">Đang bán</span>
                        <% } else { %>
                            <span class="status-badge status-cancelled">Tạm ngưng</span>
                        <% } %>
                    </td>
                    <td class="action-cell">
                        <div class="admin-actions-inline">
                            <a href="/admin/dishes/edit/<%= dish.dish_id %>" class="btn-action edit">✏️ Sửa</a>
                            <% if(dish.is_available){ %>
                                <a href="/admin/dishes/delete/<%= dish.dish_id %>" class="btn-action delete"
                                   onclick="return confirm('Ẩn món «<%= dish.dish_name %>»? Các combo có chứa món này cũng sẽ bị tạm ngưng.')">🚫 Ẩn</a>
                            <% } else { %>
                                <span class="btn-action disabled">Đã ẩn</span>
                            <% } %>
                        </div>
                    </td>
                </tr>
                <% }) %>
                </tbody>
            </table>
        </div>
    </main>
</div>
<script>
function filterTable() {
    const q = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('#dishTable tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
}
</script>
    </body>
</html>
