<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản Lý Người Dùng</title>
        <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/comque-design.css">
</head>
<body>
<div class="admin-layout">
    <%- include('../../partials/admin-sidebar', { page: 'users' }) %>
    <main class="admin-main">
        <div class="admin-topbar">
            <h2>👥 Quản Lý Người Dùng</h2>
            <span style="color:#888"><%= users.length %> tài khoản</span>
        </div>
        <div class="admin-card" style="margin:30px;">
            <div class="table-search" style="margin-bottom:16px;">
                <input type="text" id="searchInput" placeholder="🔍 Tìm theo tên, email..." oninput="filterTable()">
            </div>
            <table class="admin-table" id="userTable">
                <thead><tr>
                    <th>#</th>
                    <th>Tài khoản</th>
                    <th>Thông tin liên hệ</th>
                    <th>Địa chỉ</th>
                    <th>Vai trò</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Thao tác</th>
                </tr></thead>
                <tbody>
                <% users.forEach((u, i) => { %>
                <tr>
                    <td><%= i+1 %></td>
                    <td>
                        <strong><%= u.full_name || u.username %></strong>
                        <small style="display:block;color:#999">@<%= u.username %></small>
                    </td>
                    <td>
                        <% if(u.email) { %><div style="font-size:.85rem;">✉️ <%= u.email %></div><% } %>
                        <% if(u.phone) { %><div style="font-size:.85rem;">📞 <%= u.phone %></div><% } %>
                    </td>
                    <td style="font-size:.84rem;color:#666;max-width:160px;"><%= u.address || '—' %></td>
                    <td>
                        <select class="role-select" data-id="<%= u.user_id %>" style="padding:5px 10px;border-radius:8px;border:1.5px solid #e0e0e0;font-size:.83rem;">
                            <option value="1" <%= u.role_id==1?'selected':'' %>>⚙️ Admin</option>
                            <option value="2" <%= u.role_id==2?'selected':'' %>>👨‍🍳 Nhân viên</option>
                            <option value="3" <%= u.role_id==3?'selected':'' %>>👤 Khách hàng</option>
                        </select>
                    </td>
                    <td>
                        <% if (u.is_active === undefined || Number(u.is_active) === 1) { %>
                            <span class="status-badge status-completed">Đang hoạt động</span>
                        <% } else { %>
                            <span class="status-badge status-cancelled">Đã khóa</span>
                        <% } %>
                    </td>
                    <td style="font-size:.83rem;color:#999">
                        <%= u.created_at ? new Date(u.created_at).toLocaleDateString('vi-VN') : '—' %>
                    </td>
                    <td>
                        <% if (u.is_active === undefined || Number(u.is_active) === 1) { %>
                            <form action="/admin/users/toggle/<%= u.user_id %>" method="POST" style="display:inline;" onsubmit="return confirm('Khóa tài khoản <%= u.username %>? Tài khoản sẽ không đăng nhập được nhưng lịch sử đơn vẫn được giữ.')">
                                <button type="submit" class="btn-action delete">🔒 Khóa</button>
                            </form>
                        <% } else { %>
                            <form action="/admin/users/toggle/<%= u.user_id %>" method="POST" style="display:inline;" onsubmit="return confirm('Mở khóa tài khoản <%= u.username %>?')">
                                <button type="submit" class="btn-action" style="background:#d9f3e1;color:#0b7a2a;">🔓 Mở khóa</button>
                            </form>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
                </tbody>
            </table>
        </div>
    </main>
</div>
<script>
document.querySelectorAll('.role-select').forEach(sel => {
    sel.addEventListener('change', function() {
        const userId = this.dataset.id, roleId = this.value;
        fetch('/admin/users/update-role', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId, roleId })
        }).then(r => r.json()).then(data => {
            if(data.success) showToast('Đã cập nhật vai trò thành công');
        });
    });
});
function filterTable() {
    const q = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('#userTable tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
}
function showToast(msg) {
    const t=document.createElement('div'); t.className='toast'; t.textContent=msg;
    document.body.appendChild(t); setTimeout(()=>t.classList.add('show'),10);
    setTimeout(()=>{t.classList.remove('show');setTimeout(()=>t.remove(),300);},3000);
}
</script>
    </body>
</html>
