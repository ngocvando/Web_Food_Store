<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sửa Món Ăn</title>
        <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/comque-design.css">
</head>
<body>
<div class="admin-layout">
    <%- include('../../partials/admin-sidebar', { page: 'dishes' }) %>
    <main class="admin-main">
        <div class="admin-topbar">
            <h2>✏️ Sửa Món Ăn</h2>
            <a href="/admin/dishes" class="btn-back">← Quay lại</a>
        </div>
        <div class="admin-card" style="margin:30px;max-width:700px;">
            <form action="/admin/dishes/edit/<%= dish.dish_id %>" method="POST" enctype="multipart/form-data" class="admin-form">
                <div class="form-row">
                    <div class="form-group">
                        <label>Tên món ăn <span class="required">*</span></label>
                        <input type="text" name="dish_name" required maxlength="120" data-trim="true" value="<%= dish.dish_name %>" required>
                    </div>
                    <div class="form-group">
                        <label>Danh mục <span class="required">*</span></label>
                        <select name="category_id" required>
                            <% categories.forEach(c => { %>
                            <option value="<%= c.category_id %>" <%= dish.category_id == c.category_id ? 'selected' : '' %>>
                                <%= c.category_name %>
                            </option>
                            <% }) %>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Giá (VNĐ) <span class="required">*</span></label>
                        <input type="number" name="price" value="<%= dish.price %>" min="1" required data-positive="true" data-error="Giá món phải lớn hơn 0.">
                    </div>
                    <div class="form-group">
                        <label>Trạng thái</label>
                        <select name="is_available">
                            <option value="1" <%= dish.is_available ? 'selected' : '' %>>Đang bán</option>
                            <option value="0" <%= !dish.is_available ? 'selected' : '' %>>Tạm ngưng</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Mô tả</label>
                    <textarea name="description" rows="3"><%= dish.description %></textarea>
                </div>
                <div class="form-group">
                    <label>Ảnh chính hiện tại</label>
                    <div style="display:flex;align-items:center;gap:20px;margin-bottom:10px;">
                        <img src="/images/<%= dish.image_url %>" id="imagePreview"
                             style="width:100px;height:100px;object-fit:cover;border-radius:10px;"
                             onerror="this.src='/images/default-food.png'">
                        <div>
                            <p style="color:#888;font-size:0.88rem;">Chọn ảnh mới để thay thế ảnh chính. Ảnh chính dùng ở danh sách món.</p>
                            <div class="upload-area" id="uploadArea" style="padding:15px;">
                                <span style="font-size:1.5rem">📷</span>
                                <p style="margin:5px 0;font-size:0.9rem;">Click để chọn ảnh chính mới</p>
                                <input type="file" name="image" id="imageInput" accept="image/*" style="display:none">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Thư viện ảnh chi tiết</label>
                    <% const galleryList = (typeof dishImages !== 'undefined' && dishImages) ? dishImages : []; %>
                    <% if (galleryList.length > 0) { %>
                        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px;">
                            <% galleryList.forEach(img => { %>
                                <div style="width:112px;border:1px solid #e5e5e5;border-radius:12px;padding:8px;background:#fff;">
                                    <img src="/images/<%= img.image_url %>" style="width:94px;height:78px;object-fit:cover;border-radius:8px;" onerror="this.src='/images/default-food.png'">
                                    <% if (!img.is_main) { %>
                                        <label style="display:flex;align-items:center;gap:5px;margin-top:6px;font-size:0.82rem;color:#c0392b;">
                                            <input type="checkbox" name="delete_images" value="<%= img.image_id %>"> Xóa
                                        </label>
                                    <% } else { %>
                                        <small style="display:block;margin-top:6px;color:#5b4ae6;font-weight:700;">Ảnh chính</small>
                                    <% } %>
                                </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <p style="color:#777;font-size:0.9rem;">Món này chưa có ảnh phụ. Hệ thống sẽ dùng ảnh chính trong trang chi tiết.</p>
                    <% } %>
                    <input type="file" name="gallery_images" id="galleryInput" accept="image/*" multiple>
                    <p style="color:#777;font-size:0.9rem;margin-top:6px;">Chọn thêm nhiều ảnh phụ cho trang chi tiết món ăn.</p>
                    <div id="galleryPreview" style="display:flex;gap:10px;flex-wrap:wrap;margin-top:10px;"></div>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn-admin-save">💾 Lưu Thay Đổi</button>
                    <a href="/admin/dishes" class="btn-admin-cancel">Hủy</a>
                </div>
            </form>
        </div>
    </main>
</div>
<script>
const area = document.getElementById('uploadArea');
const input = document.getElementById('imageInput');
const preview = document.getElementById('imagePreview');
area.addEventListener('click', () => input.click());
input.addEventListener('change', function() {
    if (this.files[0]) {
        const reader = new FileReader();
        reader.onload = e => { preview.src = e.target.result; };
        reader.readAsDataURL(this.files[0]);
    }
});

const galleryInput = document.getElementById('galleryInput');
const galleryPreview = document.getElementById('galleryPreview');
galleryInput.addEventListener('change', function() {
    galleryPreview.innerHTML = '';
    Array.from(this.files || []).forEach(file => {
        if (!file.type.startsWith('image/')) return;
        const reader = new FileReader();
        reader.onload = e => {
            const img = document.createElement('img');
            img.src = e.target.result;
            img.style.cssText = 'width:82px;height:82px;object-fit:cover;border-radius:10px;border:1px solid #ddd;';
            galleryPreview.appendChild(img);
        };
        reader.readAsDataURL(file);
    });
});
</script>
    </body>
</html>
