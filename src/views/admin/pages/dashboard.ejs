<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Cơm Quê Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/comque-design.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .dashboard-section{margin-top:22px}.dashboard-kpi-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:16px}.dashboard-kpi-card{background:#fff;border:1px solid var(--dm-hairline);border-radius:16px;padding:20px;box-shadow:none}.dashboard-kpi-card p{margin:0;color:var(--dm-steel);font-weight:800;font-size:.88rem}.dashboard-kpi-card h3{margin:10px 0 0;color:var(--dm-ink);font-size:1.55rem;letter-spacing:-.03em}.dashboard-kpi-card small{display:block;margin-top:6px;color:var(--dm-slate);font-size:.8rem}.dashboard-kpi-card:nth-child(4n+1){background:var(--dm-lavender)}.dashboard-kpi-card:nth-child(4n+2){background:var(--dm-mint)}.dashboard-kpi-card:nth-child(4n+3){background:var(--dm-yellow)}.dashboard-kpi-card:nth-child(4n){background:var(--dm-sky)}.dashboard-analytics-grid{display:grid;grid-template-columns:1.25fr .75fr;gap:18px}.dashboard-two-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px}.dashboard-three-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:18px}.dashboard-card-clean{background:#fff;border:1px solid var(--dm-hairline);border-radius:16px;padding:22px;overflow:hidden}.dashboard-card-clean h2{margin:0;color:var(--dm-ink);font-size:1.18rem;letter-spacing:-.02em}.dashboard-card-clean .sub{margin:6px 0 18px;color:var(--dm-steel);font-size:.9rem}.dashboard-list{display:flex;flex-direction:column;gap:10px}.dashboard-list-row{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px;border:1px solid var(--dm-hairline-soft);border-radius:12px;background:var(--dm-surface-soft)}.dashboard-list-main{min-width:0}.dashboard-list-main strong{display:block;color:var(--dm-ink);font-size:.92rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.dashboard-list-main span{display:block;margin-top:3px;color:var(--dm-steel);font-size:.8rem}.dashboard-list-value{text-align:right;font-weight:900;color:var(--dm-primary);white-space:nowrap}.dashboard-chart-box{height:260px}.dashboard-small-chart{height:230px}.dashboard-alerts{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}.dashboard-alert{border:1px solid var(--dm-hairline);border-radius:14px;padding:15px;background:#fff}.dashboard-alert strong{display:block;font-size:1.35rem;color:var(--dm-ink)}.dashboard-alert span{display:block;margin-top:5px;color:var(--dm-steel);font-size:.84rem}.review-stars{color:#f5a623;letter-spacing:1px}.dashboard-empty{padding:18px;border:1px dashed var(--dm-hairline-strong);border-radius:12px;color:var(--dm-steel);background:var(--dm-surface-soft);text-align:center;font-size:.9rem}.dashboard-table-mini{width:100%;border:0!important}.dashboard-table-mini th,.dashboard-table-mini td{padding:10px 8px!important}.dashboard-table-mini th{background:var(--dm-surface)!important;color:var(--dm-steel)!important}.dashboard-note{font-size:.84rem;color:var(--dm-steel);margin-top:10px;line-height:1.5}@media(max-width:1180px){.dashboard-kpi-grid,.dashboard-alerts{grid-template-columns:repeat(2,minmax(0,1fr))}.dashboard-analytics-grid,.dashboard-two-grid,.dashboard-three-grid{grid-template-columns:1fr}}@media(max-width:640px){.dashboard-kpi-grid,.dashboard-alerts{grid-template-columns:1fr}.dashboard-card-clean{padding:18px}.dashboard-chart-box,.dashboard-small-chart{height:220px}}
    </style>
</head>
<body class="design-dashboard-body">
<div class="design-dashboard-layout">
    <%- include('../../partials/admin-sidebar', { page: 'dashboard' }) %>

    <main class="design-dashboard-main">
        <header class="design-dashboard-topbar">
            <div class="design-search-box">
                <span>🔎</span>
                <input type="text" placeholder="Tìm đơn hàng, món ăn, khách hàng...">
            </div>
            <div class="design-user-box">
                <button class="design-icon-btn">🔔</button>
                <div class="design-user-pill">
                    <span>Admin</span>
                    <strong><%= user && user.username ? user.username : 'Quản trị viên' %></strong>
                </div>
            </div>
        </header>

        <section class="design-hero-band">
            <span class="design-dot design-dot-1"></span>
            <span class="design-dot design-dot-2"></span>
            <span class="design-dot design-dot-3"></span>
            <div class="design-hero-content">
                <p>Bảng điều khiển Cơm Quê</p>
                <h1>Theo dõi kinh doanh, vận hành và trải nghiệm khách hàng.</h1>
                <span>Dashboard tổng hợp doanh thu, đơn hàng, món bán chạy, combo, đánh giá, mã giảm giá và phí giao hàng.</span>
            </div>
            <div class="design-hero-actions">
                <a href="/admin/orders" class="design-btn-primary">Xem đơn hàng</a>
                <a href="/admin/dishes/add" class="design-btn-secondary-dark">Thêm món</a>
            </div>
        </section>

        <section class="dashboard-section dashboard-kpi-grid">
            <article class="dashboard-kpi-card"><p>Doanh thu hoàn thành</p><h3><%= Number(stats.revenue || 0).toLocaleString('vi-VN') %> ₫</h3><small>Chỉ tính đơn Completed, Banking đã Paid.</small></article>
            <article class="dashboard-kpi-card"><p>Đơn hàng</p><h3><%= Number(stats.orders || 0).toLocaleString('vi-VN') %></h3><small><%= Number(stats.completedOrders || 0).toLocaleString('vi-VN') %> đơn hoàn thành.</small></article>
            <article class="dashboard-kpi-card"><p>Giá trị TB/đơn</p><h3><%= Number(stats.avgOrderValue || 0).toLocaleString('vi-VN') %> ₫</h3><small>Tính trên đơn hoàn thành.</small></article>
            <article class="dashboard-kpi-card"><p>Đánh giá trung bình</p><h3><%= Number(stats.avgRating || 0).toFixed(1) %> ★</h3><small><%= Number(stats.totalReviews || 0).toLocaleString('vi-VN') %> đánh giá.</small></article>
            <article class="dashboard-kpi-card"><p>Món đang bán</p><h3><%= Number(stats.dishes || 0).toLocaleString('vi-VN') %></h3><small>Món có trạng thái còn bán.</small></article>
            <article class="dashboard-kpi-card"><p>Người dùng</p><h3><%= Number(stats.users || 0).toLocaleString('vi-VN') %></h3><small>Tổng tài khoản hệ thống.</small></article>
            <article class="dashboard-kpi-card"><p>Tổng phí ship</p><h3><%= Number(stats.totalShipping || 0).toLocaleString('vi-VN') %> ₫</h3><small>Thu từ đơn hoàn thành.</small></article>
            <article class="dashboard-kpi-card"><p>Khoảng cách TB</p><h3><%= Number(stats.avgDistance || 0).toFixed(1) %> km</h3><small>Theo địa chỉ giao hàng.</small></article>
        </section>

        <section class="dashboard-section dashboard-alerts">
            <div class="dashboard-alert"><strong><%= Number(alerts?.pendingOrders || 0) %></strong><span>Đơn chờ xác nhận</span></div>
            <div class="dashboard-alert"><strong><%= Number(alerts?.preparingOrders || 0) %></strong><span>Đơn đang chế biến</span></div>
            <div class="dashboard-alert"><strong><%= Number(alerts?.pendingPayments || 0) %></strong><span>Chuyển khoản chờ xác nhận</span></div>
            <div class="dashboard-alert"><strong><%= Number(alerts?.hiddenDishes || 0) %></strong><span>Món đang tạm ẩn</span></div>
        </section>

        <section class="dashboard-section dashboard-analytics-grid">
            <article class="dashboard-card-clean">
                <h2>Doanh thu 7 ngày gần nhất</h2>
                <p class="sub">Doanh thu được tính từ đơn đã hoàn thành.</p>
                <div class="dashboard-chart-box"><canvas id="revenueChart"></canvas></div>
            </article>
            <article class="dashboard-card-clean">
                <h2>Trạng thái đơn hàng</h2>
                <p class="sub">Tỷ lệ đơn theo trạng thái xử lý.</p>
                <div class="dashboard-small-chart"><canvas id="orderStatusChart"></canvas></div>
            </article>
        </section>

        <section class="dashboard-section dashboard-two-grid">
            <article class="dashboard-card-clean">
                <h2>Top món bán chạy</h2>
                <p class="sub">Tính theo số lượng bán trong đơn Completed.</p>
                <% if (topDishes && topDishes.length) { %>
                    <div class="dashboard-list">
                        <% topDishes.forEach((item, index) => { %>
                            <div class="dashboard-list-row"><div class="dashboard-list-main"><strong>#<%= index + 1 %> <%= item.name %></strong><span>Đã bán <%= Number(item.sold_quantity || 0) %> phần</span></div><div class="dashboard-list-value"><%= Number(item.revenue || 0).toLocaleString('vi-VN') %> ₫</div></div>
                        <% }) %>
                    </div>
                <% } else { %><div class="dashboard-empty">Chưa có dữ liệu món bán chạy.</div><% } %>
            </article>
            <article class="dashboard-card-clean">
                <h2>Top combo bán chạy</h2>
                <p class="sub">Theo số lượng combo đã bán.</p>
                <% if (topCombos && topCombos.length) { %>
                    <div class="dashboard-list">
                        <% topCombos.forEach((item, index) => { %>
                            <div class="dashboard-list-row"><div class="dashboard-list-main"><strong>#<%= index + 1 %> <%= item.name %></strong><span>Đã bán <%= Number(item.sold_quantity || 0) %> combo</span></div><div class="dashboard-list-value"><%= Number(item.revenue || 0).toLocaleString('vi-VN') %> ₫</div></div>
                        <% }) %>
                    </div>
                <% } else { %><div class="dashboard-empty">Chưa có dữ liệu combo bán chạy.</div><% } %>
            </article>
        </section>

        <section class="dashboard-section dashboard-three-grid">
            <article class="dashboard-card-clean">
                <h2>Doanh thu theo danh mục</h2>
                <p class="sub">Nhóm món tạo doanh thu tốt nhất.</p>
                <div class="dashboard-small-chart"><canvas id="categoryRevenueChart"></canvas></div>
            </article>
            <article class="dashboard-card-clean">
                <h2>Mã giảm giá</h2>
                <p class="sub">Số lần dùng và tổng tiền đã giảm.</p>
                <% if (discountStats && discountStats.length) { %>
                    <table class="dashboard-table-mini"><thead><tr><th>Mã</th><th>Lượt</th><th>Đã giảm</th></tr></thead><tbody>
                    <% discountStats.forEach(d => { %><tr><td><strong><%= d.code %></strong></td><td><%= Number(d.used_count || 0) %></td><td><%= Number(d.total_discount || 0).toLocaleString('vi-VN') %> ₫</td></tr><% }) %>
                    </tbody></table>
                <% } else { %><div class="dashboard-empty">Chưa có mã giảm giá nào được sử dụng.</div><% } %>
            </article>
            <article class="dashboard-card-clean">
                <h2>Phân bố đánh giá</h2>
                <p class="sub">Tổng hợp số lượng đánh giá theo sao.</p>
                <div class="dashboard-small-chart"><canvas id="ratingChart"></canvas></div>
            </article>
        </section>

        <section class="dashboard-section dashboard-two-grid">
            <article class="dashboard-card-clean">
                <h2>Đánh giá mới nhất</h2>
                <p class="sub">Phản hồi gần đây từ khách hàng.</p>
                <% if (latestReviews && latestReviews.length) { %>
                    <div class="dashboard-list">
                        <% latestReviews.forEach(r => { %>
                            <div class="dashboard-list-row"><div class="dashboard-list-main"><strong><%= r.full_name || 'Khách hàng' %></strong><span><%= r.comment %></span></div><div class="dashboard-list-value review-stars"><%= '★'.repeat(Number(r.rating || 0)) %></div></div>
                        <% }) %>
                    </div>
                <% } else { %><div class="dashboard-empty">Hiện tại chưa có đánh giá nào từ khách hàng.</div><% } %>
            </article>
            <article class="dashboard-card-clean">
                <h2>Đơn hàng gần đây</h2>
                <p class="sub">Các đơn mới nhất và trạng thái xử lý.</p>
                <div class="design-table-wrap">
                    <table class="design-orders-table">
                        <thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Trạng thái</th></tr></thead>
                        <tbody>
                        <% if (recentOrders && recentOrders.length) { %>
                            <% recentOrders.forEach(o => { %>
                                <tr><td><strong>#<%= o.order_id %></strong></td><td><%= o.full_name || 'Khách hàng' %></td><td><span class="status-badge status-<%= String(o.order_status || 'pending').toLowerCase() %>"><%= o.order_status %></span></td></tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="3" class="design-empty-row">Chưa có đơn hàng gần đây.</td></tr>
                        <% } %>
                        </tbody>
                    </table>
                </div>
                <p class="dashboard-note"><a href="/admin/orders" class="design-btn-outline">Xem tất cả đơn hàng</a></p>
            </article>
        </section>
    </main>
</div>

<script>
const chartData = <%- JSON.stringify(chartData || []) %>;
const orderStatusStats = <%- JSON.stringify(orderStatusStats || []) %>;
const revenueByCategory = <%- JSON.stringify(revenueByCategory || []) %>;
const ratingStats = <%- JSON.stringify(ratingStats || []) %>;

function makeChart(id, config) {
    const el = document.getElementById(id);
    if (el) new Chart(el, config);
}

makeChart('revenueChart', {
    type: 'bar',
    data: { labels: chartData.map(d => d.date), datasets: [{ label: 'Doanh thu (₫)', data: chartData.map(d => Number(d.daily_revenue || 0)), backgroundColor: '#5645d4', borderColor: '#4534b3', borderWidth: 1, borderRadius: 8, maxBarThickness: 42 }] },
    options: { responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}}, scales:{x:{grid:{display:false},ticks:{color:'#787671'}}, y:{beginAtZero:true,grid:{color:'#ede9e4'},ticks:{color:'#787671'}}} }
});

makeChart('orderStatusChart', {
    type: 'doughnut',
    data: { labels: orderStatusStats.map(x => x.order_status || 'Không rõ'), datasets: [{ data: orderStatusStats.map(x => Number(x.total || 0)), backgroundColor: ['#5645d4','#1aae39','#dd5b00','#dcecfa','#fde0ec','#f9e79f'], borderWidth: 0 }] },
    options: { responsive:true, maintainAspectRatio:false, plugins:{legend:{position:'bottom'}} }
});

makeChart('categoryRevenueChart', {
    type: 'bar',
    data: { labels: revenueByCategory.map(x => x.category_name), datasets: [{ data: revenueByCategory.map(x => Number(x.revenue || 0)), backgroundColor: '#1a1a1a', borderRadius: 8, maxBarThickness: 34 }] },
    options: { indexAxis:'y', responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}}, scales:{x:{beginAtZero:true,grid:{color:'#ede9e4'}}, y:{grid:{display:false}}} }
});

makeChart('ratingChart', {
    type: 'bar',
    data: { labels: ratingStats.map(x => `${x.rating}★`), datasets: [{ data: ratingStats.map(x => Number(x.total || 0)), backgroundColor: '#f5d75e', borderRadius: 8, maxBarThickness: 36 }] },
    options: { responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}}, scales:{x:{grid:{display:false}}, y:{beginAtZero:true,grid:{color:'#ede9e4'}}} }
});
</script>
</body>
</html>
