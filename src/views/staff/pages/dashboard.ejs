<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nhân Viên - Dashboard</title>
        <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/comque-design.css">
</head>
<body>
<div class="admin-layout">
    <%- include('../../partials/staff-sidebar') %>
    <main class="admin-main">
        <div class="admin-topbar">
            <h2>📊 Dashboard Nhân Viên</h2>
            <span>Xin chào, <strong><%= user.username %></strong> 👋</span>
        </div>

        <div class="stats-grid">
            <div class="stat-card blue">
                <div class="stat-icon">⏳</div>
                <div class="stat-info"><h3><%= stats.pending %></h3><p>Chờ xác nhận</p></div>
            </div>
            <div class="stat-card green">
                <div class="stat-icon">🍳</div>
                <div class="stat-info"><h3><%= stats.preparing %></h3><p>Đang chế biến</p></div>
            </div>
            <div class="stat-card red">
                <div class="stat-icon">📋</div>
                <div class="stat-info"><h3><%= stats.todayOrders %></h3><p>Đơn hàng hôm nay</p></div>
            </div>
            <div class="stat-card purple">
                <div class="stat-icon">💰</div>
                <div class="stat-info"><h3><%= Number(stats.todayRevenue).toLocaleString('vi-VN') %> ₫</h3><p>Doanh thu hôm nay</p></div>
            </div>
        </div>

        <div class="admin-card" style="margin:0 30px 30px;">
            <h3 style="margin-bottom:20px;">📋 Đơn Hàng Gần Đây</h3>
            <% if(recentOrders.length === 0) { %>
                <p style="color:#aaa;text-align:center;padding:30px;">Chưa có đơn hàng.</p>
            <% } else { %>
            <table class="admin-table">
                <thead><tr>
                    <th>Mã đơn</th>
                    <th>Khách hàng</th>
                    <th>SĐT</th>
                    <th>Địa chỉ giao</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Cập nhật</th>
                </tr></thead>
                <tbody>
                <% recentOrders.forEach(order => { %>
                <tr data-status="<%= order.order_status %>">
                    <td><strong>#<%= order.order_id %></strong><br><small style="color:#999"><%= new Date(order.order_date).toLocaleDateString('vi-VN') %></small></td>
                    <td><strong><%= order.full_name %></strong><br><small style="color:#999"><%= order.receiver_name || '' %></small></td>
                    <td><%= order.delivery_phone || order.phone || '—' %></td>
                    <td style="max-width:180px;font-size:0.85rem;color:#555"><%= order.delivery_address || order.user_address || '—' %></td>
                    <td class="price-cell"><%= Number(order.total_amount).toLocaleString('vi-VN') %> ₫</td>
                    <td>
                        <span class="status-badge status-<%= order.order_status.toLowerCase() %>">
                            <% const lbl = {Pending:'⏳ Chờ xác nhận',Preparing:'🍳 Chế biến',Shipping:'🚚 Đang giao',Completed:'✅ Hoàn thành',Cancelled:'❌ Đã hủy'} %>
                            <%= lbl[order.order_status] %>
                        </span>
                    </td>
                    <td>
                        <select class="status-select" data-id="<%= order.order_id %>" data-current="<%= order.order_status %>" <%= (order.order_status === 'Completed' || order.order_status === 'Cancelled') ? 'disabled' : '' %>>
                            <option value="Pending"   <%= order.order_status=='Pending'   ?'selected':'' %>>Chờ xác nhận</option>
                            <option value="Preparing" <%= order.order_status=='Preparing' ?'selected':'' %>>Đang chế biến</option>
                            <option value="Shipping"  <%= order.order_status=='Shipping'  ?'selected':'' %>>Đang giao</option>
                            <option value="Completed" <%= order.order_status=='Completed' ?'selected':'' %>>Hoàn thành</option>
                            <option value="Cancelled" <%= order.order_status=='Cancelled' ?'selected':'' %>>Hủy đơn</option>
                        </select>
                    </td>
                </tr>
                <% }) %>
                </tbody>
            </table>
            <div style="margin-top:16px;text-align:right">
                <a href="/staff/orders" class="view-all-link">Xem tất cả đơn hàng →</a>
            </div>
            <% } %>
        </div>
    </main>
</div>
<script>
document.querySelectorAll('.status-select').forEach(select => {
    select.addEventListener('change', function() {
        const orderId = this.dataset.id;
        const newStatus = this.value;
        fetch('/staff/orders/update-status', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ orderId, status: newStatus })
        }).then(r => r.json()).then(data => {
            if (!data.success) {
                alert(data.message || 'Không thể cập nhật trạng thái.');
                this.value = this.dataset.current;
                return;
            }
            if (data.success) {
                const row = this.closest('tr');
                row.dataset.status = newStatus;
                const badge = row.querySelector('.status-badge');
                const labels = {Pending:'⏳ Chờ xác nhận',Preparing:'🍳 Chế biến',Shipping:'🚚 Đang giao',Completed:'✅ Hoàn thành',Cancelled:'❌ Đã hủy'};
                badge.textContent = labels[newStatus];
                badge.className = `status-badge status-${newStatus.toLowerCase()}`;
                this.dataset.current = newStatus;
                if (newStatus === 'Completed' || newStatus === 'Cancelled') this.disabled = true;
                showToast(`Đã cập nhật #${orderId} → ${labels[newStatus]}`);
            }
        });
    });
});
function showToast(msg) {
    const t = document.createElement('div'); t.className='toast'; t.textContent=msg;
    document.body.appendChild(t); setTimeout(()=>t.classList.add('show'),10);
    setTimeout(()=>{t.classList.remove('show');setTimeout(()=>t.remove(),300);},3000);
}
</script>
    </body>
</html>
