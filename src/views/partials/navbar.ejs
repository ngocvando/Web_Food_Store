<nav class="navbar">
    <div class="nav-container">
        <a href="/" class="nav-logo brand-logo-link">
            <img src="/images/comque-logo.png" alt="Logo Cơm Quê" class="brand-logo-img">
            <span class="brand-logo-text">Cơm<span class="logo-red"> Quê</span></span>
        </a>
        <ul class="nav-links">
            <li><a href="/">Trang chủ</a></li>
            <li><a href="/thuc-don">Thực Đơn</a></li>
            <% if (user && user.userId) { %>
                <% if (user.roleId === 3) { %>
                <li><a href="/cart" style="position:relative;">🛒 Giỏ hàng <span id="cart-badge" class="cart-badge" style="<%= cartCount > 0 ? 'display:flex' : 'display:none' %>"><%= cartCount %></span></a></li>
                <li><a href="/my-orders">Đơn hàng</a></li>
                <% } %>
                <% if (user.roleId === 1) { %>
                    <li><a href="/admin/dashboard" style="color:#5645d4;font-weight:600;">⚙️ Admin</a></li>
                <% } else if (user.roleId === 2) { %>
                    <li><a href="/staff/dashboard" style="color:#dd5b00;font-weight:600;">👨‍🍳 Nhân viên</a></li>
                <% } %>
                <li class="nav-user-menu">
                    <details>
                        <summary aria-label="Mở menu tài khoản">☰</summary>
                        <div class="nav-user-dropdown">
                            <% if (user.roleId === 3) { %>
                                <a href="/profile">👤 Tài khoản</a>
                            <% } %>
                            <a href="/logout">🚪 Đăng xuất</a>
                        </div>
                    </details>
                </li>
            <% } else { %>
                <li><a href="/login" class="btn-nav-login">Đăng nhập</a></li>
                <li><a href="/register" class="btn-nav-register">Đăng ký</a></li>
            <% } %>
        </ul>
    </div>
</nav>
