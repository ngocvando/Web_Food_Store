<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css"> </head>
<body>
    <h1>Thực đơn hôm nay</h1>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
        <% dishes.forEach(dish => { %>
            <div class="card" style="border: 1px solid #ccc; padding: 15px;">
                <img src="/images/<%= dish.image_url %>" alt="<%= dish.dish_name %>" style="width: 100%;">
                <h3><%= dish.dish_name %></h3>
                <p>Loại: <%= dish.category_name %></p>
                <p style="color: red; font-weight: bold;">
                    <%= dish.price.toLocaleString('vi-VN') %> VNĐ
                </p>
                <button>Thêm vào giỏ hàng</button>
            </div>
        <% }) %>
    </div>
</body>
</html>